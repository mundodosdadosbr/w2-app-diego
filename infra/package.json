    "aws-cdk-lib": "2.162.1",
    "constructs": "10.3.0"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "aws-cdk": "2.162.1",
    "ts-node": "10.9.2",
    "typescript": "5.6.3"
  }
}
