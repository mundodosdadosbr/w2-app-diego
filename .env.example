# ============================================================================
# .env.example — shape das variáveis esperadas.
# Copie para .env e preencha. NUNCA commite .env.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase (frontend-safe + server-only)
# ----------------------------------------------------------------------------
# Frontend (NEXT_PUBLIC_*): seguras no bundle.
NEXT_PUBLIC_SUPABASE_URL=https://ucbbhymgflujbtcopaeb.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only: NUNCA expor ao cliente. Usada só em Server Actions / route handlers.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example.DO_NOT_SHIP_TO_CLIENT

# ----------------------------------------------------------------------------
# AWS (só em Supabase Edge Functions — via supabase secrets set)
# NÃO preencher aqui em produção; preencher via: supabase secrets set AWS_ACCESS_KEY_ID=...
# ----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAEXAMPLE_REPLACE
AWS_SECRET_ACCESS_KEY=EXAMPLE_REPLACE
AWS_S3_UPLOADS_BUCKET=w2-stt-uploads
AWS_S3_RECORDINGS_BUCKET=w2-recordings

# Modelos Bedrock (IDs podem evoluir — conferir docs e ajustar)
BEDROCK_MODEL_TUTOR=anthropic.claude-sonnet-4-6-20260101-v1:0
BEDROCK_MODEL_SPEAKING=anthropic.claude-sonnet-4-6-20260101-v1:0
BEDROCK_MODEL_CORRECTOR=anthropic.claude-opus-4-7-20260101-v1:0
BEDROCK_MODEL_RECOMMENDER=anthropic.claude-opus-4-7-20260101-v1:0
BEDROCK_MODEL_PRONUNCIATION=anthropic.claude-haiku-4-5-20260101-v1:0

# Transcribe custom vocabulary prefix (1 vocab por lesson)
TRANSCRIBE_VOCAB_PREFIX=w2-lesson-

# ----------------------------------------------------------------------------
# Anthropic direta (fallback — ver ADR-017)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-example_replace

# ----------------------------------------------------------------------------
# ElevenLabs TTS (primário — ADR-005)
# ----------------------------------------------------------------------------
ELEVENLABS_API_KEY=sk_example_replace
ELEVENLABS_VOICE_ID_FEMALE=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID_MALE=pNInz6obpgDQGcFmaJgB
ELEVENLABS_VOICE_ID_TUTOR=ErXwobaYiN019PkySvjV

# ----------------------------------------------------------------------------
# OpenAI (fallback TTS)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-example_replace

# ----------------------------------------------------------------------------
# Observabilidade
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://example@sentry.io/project
SENTRY_AUTH_TOKEN=sntrys_example_replace
NEXT_PUBLIC_POSTHOG_KEY=phc_example
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ----------------------------------------------------------------------------
# Ambiente
# ----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# CI / deploy
